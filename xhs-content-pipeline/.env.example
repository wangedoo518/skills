# 复制本文件为 .env 然后填入真实 key
# .env 不会进 git（在 .gitignore 里排除了）

# FreeModel API（OpenAI 兼容格式）
FREEMODEL_API_KEY=sk-your-key-here
FREEMODEL_BASE_URL=https://api.freemodel.dev/v1
FREEMODEL_MODEL=gpt-5.5

# 备选：Anthropic 格式（如果想用 /v1/messages 接口）
# FREEMODEL_API_KEY=sk-your-key-here
# FREEMODEL_BASE_URL=https://cc.freemodel.dev
# FREEMODEL_MODEL=claude-sonnet-4-6
